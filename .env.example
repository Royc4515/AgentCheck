# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# --- Groq (primary LLM provider for parts 1-3) ---
GROQ_API_KEY=gsk_...

# --- Gemini (used for Part 4 verdict — takes priority over Groq if set) ---
GEMINI_API_KEY=AIza...

# --- Local Podman/Ollama fallback (optional) ---
# Automatically used when Groq fails or rate-limits.
# Ollama in Podman Desktop AI Lab:
LOCAL_LLM_URL=http://localhost:10434/v1/chat/completions
LOCAL_LLM_MODEL=ibm-granite/granite-4.0-micro-GGUF
